# Copy to .env for local use. NEVER commit real values.

# Neon Postgres connection string (pgvector must be available)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Comma-separated Gemini free-tier API keys (any count, 1..N).
# ALL keys are shared: the runtime app rotates across every key per request
# (with cooldown/bench handling), and the ingestion pipeline rotates over
# the same set. One key works; more keys raise both quotas.
GEMINI_API_KEYS=your-key-1,your-key-2,your-key-3

# Optional: override the Gemini model used for question extraction.
# Must be a model with free-tier quota (retired models report "limit: 0").
# GEMINI_MODEL=gemini-3.1-flash-lite
