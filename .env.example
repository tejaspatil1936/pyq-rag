# Copy to .env for local use. NEVER commit real values.

# Neon Postgres connection string (pgvector must be available)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Comma-separated Gemini free-tier API keys (any count, 1..N).
# The LAST key is reserved for the runtime app (/api/ask) and is never used
# by the ingestion pipeline. All other keys form the ingestion rotation pool.
GEMINI_API_KEYS=your-pool-key-1,your-pool-key-2,your-runtime-key

# Optional: override the Gemini model used for question extraction
# GEMINI_MODEL=gemini-2.0-flash
